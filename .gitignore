# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.env/
.venv/

# Environment variables (VERY IMPORTANT)
.env
.env.*

# VS Code / IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# SQLite (if you ever use it)
*.db

# PostgreSQL dump files
*.sql

# Uvicorn / FastAPI
*.pid

# Coverage / testing
.coverage
htmlcov/
.pytest_cache/

# Build / dist
build/
dist/
*.egg-info/

# Migrations (optional: depends if you use Alembic)
alembic/versions/*.pyc

# Node (if you add React Native later in same repo)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Expo / React Native
.expo/
.expo-shared/